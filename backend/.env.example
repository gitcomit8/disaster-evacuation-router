# Backend Environment Variables
PORT=5000
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# WebSocket Configuration
WS_CORS_ORIGIN=http://localhost:5173

# Algorithm Tuning Parameters
COST_ALPHA=1.0
COST_BETA=0.5
COST_GAMMA=2.0

# Hazard Simulation
HAZARD_SPAWN_INTERVAL=5000
HAZARD_EXPANSION_RATE=0.1
HAZARD_MAX_RADIUS=500
